{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "verbatimModuleSyntax": true,
    "strict": true,
    "skipLibCheck": true,
    "lib": ["ESNext"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "outDir": "dist",
    "declaration": true,
    "sourceMap": true,

    // composite true is only needed when it's being referenced in another tsconfig workspace
    "composite": true
  },
  "exclude": ["node_modules", "drizzle", "dist", "bun.lock"]
}

{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "root": true,
  "files": {
    "ignoreUnknown": true,
    "includes": ["**"]
  },
  "linter": {
    "rules": {
      "style": {
        "noMagicNumbers": "off"
      }
    }
  },
  "javascript": {
    "globals": ["Bun"]
  },
  "extends": ["ultracite/core"]
}

{
  "name": "@fresclean/api",
  "type": "module",
  "version": "0.0.1",
  "sideEffects": false,
  "exports": {
    "./rpc": {
      "import": {
        "default": "./dist/rpc.js",
        "types": "./dist/rpc.d.ts"
      }
    },
    "./types": {
      "import": {
        "default": "./dist/types/index.js",
        "types": "./dist/types/index.d.ts"
      }
    },
    "./schema": {
      "import": {
        "default": "./dist/schema/index.js",
        "types": "./dist/schema/index.d.ts"
      }
    }
  },
  "scripts": {
    "dev": "bun --bun concurrently -k -n server,types -c blue,magenta \"bun run --hot src/index.ts\" \"bun --bun tsdown --watch\"",
    "build": "bun --bun tsdown",
    "build:types": "bun --bun tsdown",
    "lint": "biome check .",
    "type-check": "tsc -b",
    "seed:dev": "bun run src/db/seed.ts",
    "pull:dev": "bun drizzle-kit pull --config=drizzle-dev.config.ts",
    "build:watch": "bun tsdown --watch",
    "pull:prod": "bun drizzle-kit pull --config=drizzle-prod.config.ts",
    "push:dev": "bun drizzle-kit push --config=drizzle-dev.config.ts",
    "push:prod": "bun drizzle-kit push --config=drizzle-prod.config.ts",
    "generate:dev": "bun drizzle-kit generate --config=drizzle-dev.config.ts",
    "generate:prod": "bun drizzle-kit generate --config=drizzle-prod.config.ts",
    "migrate:dev": "bun drizzle-kit migrate --config=drizzle-dev.config.ts",
    "migrate:prod": "bun drizzle-kit migrate --config=drizzle-prod.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.924.0",
    "@aws-sdk/s3-request-presigner": "^3.924.0",
    "@faker-js/faker": "^10.3.0",
    "@hono/zod-validator": "^0.7.4",
    "@neondatabase/serverless": "^1.0.2",
    "dayjs": "catalog:",
    "drizzle-orm": "beta",
    "hono": "^4.11.4",
    "http-status-codes": "^2.3.0",
    "libphonenumber-js": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:",
    "@types/bun": "latest",
    "concurrently": "^9.2.1",
    "drizzle-kit": "beta",
    "tsdown": "^0.21.7",
    "typescript": "^5.9.3",
    "ultracite": "catalog:"
  }
}

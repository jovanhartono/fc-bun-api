{
  "name": "@fresclean/api",
  "type": "module",
  "version": "0.0.1",
  "sideEffects": false,
  "exports": {
    "./rpc": {
      "import": {
        "default": "./dist/src/rpc.js",
        "types": "./dist/src/rpc.d.ts"
      }
    },
    "./types": {
      "import": {
        "default": "./dist/src/types/index.js",
        "types": "./dist/src/types/index.d.ts"
      }
    },
    "./schema": {
      "import": {
        "default": "./dist/src/schema/index.js",
        "types": "./dist/src/schema/index.d.ts"
      }
    }
  },
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "pull:dev": "bun drizzle-kit pull --config=drizzle-dev.config.ts",
    "tsdown": "tsdown --watch",
    "pull:prod": "bun drizzle-kit pull --config=drizzle-prod.config.ts",
    "push:dev": "bun drizzle-kit push --config=drizzle-dev.config.ts",
    "push:prod": "bun drizzle-kit push --config=drizzle-prod.config.ts",
    "generate:dev": "bun drizzle-kit generate --config=drizzle-dev.config.ts",
    "generate:prod": "bun drizzle-kit generate --config=drizzle-prod.config.ts",
    "migrate:dev": "bun drizzle-kit migrate --config=drizzle-dev.config.ts",
    "migrate:prod": "bun drizzle-kit migrate --config=drizzle-prod.config.ts"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.4",
    "@neondatabase/serverless": "^1.0.2",
    "drizzle-orm": "^0.44.7",
    "drizzle-zod": "catalog:",
    "hono": "^4.10.3",
    "http-status-codes": "^2.3.0",
    "libphonenumber-js": "catalog:",
    "zod": "catalog:",
    "dayjs": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.2",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.5",
    "tsdown": "^0.15.11",
    "typescript": "^5.9.3",
    "ultracite": "6.1.0"
  }
}

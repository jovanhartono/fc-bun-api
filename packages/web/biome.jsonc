{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"root": false,
	"files": {
		"includes": ["**", "!**/*.css", "!**/*.gen.ts"]
	},
	"extends": ["ultracite/biome/react"],
	"linter": {
		"rules": {
			"suspicious": {
				"noArrayIndexKey": "off"
			}
		}
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	}
}

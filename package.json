{
  "name": "fresclean",
  "type": "module",
  "sideEffects": false,
  "private": true,
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "prepare": "husky"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "catalog": {
    "dayjs": "^1.11.21",
    "zod": "^4.4.3",
    "typescript": "^6",
    "libphonenumber-js": "^1.13.5",
    "@biomejs/biome": "2.4.16",
    "hono": "^4.11.4",
    "ultracite": "7.8.1"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "turbo": "^2.9.16"
  },
  "lint-staged": {
    "*": "bunx biome check --write --no-errors-on-unmatched"
  }
}

{
  "name": "fresclean",
  "type": "module",
  "sideEffects": false,
  "private": true,
  "packageManager": "bun@1.3.12",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "catalog": {
    "dayjs": "^1.11.19",
    "zod": "^4",
    "typescript": "^5",
    "libphonenumber-js": "^1.12.25",
    "@biomejs/biome": "2.3.11",
    "hono": "^4.11.4",
    "ultracite": "7.0.11"
  },
  "devDependencies": {
    "lint-staged": "^16.4.0",
    "turbo": "^2.9.6"
  },
  "lint-staged": {
    "*": "bunx biome check --write --no-errors-on-unmatched"
  }
}
